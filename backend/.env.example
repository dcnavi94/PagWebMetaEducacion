# =============================================================================
# PLATAFORMA ESCOLAR UNIVES - Configuracion de Entorno
# =============================================================================
# Copia este archivo como .env y ajusta los valores para tu entorno.
# NUNCA subas el archivo .env real al repositorio (contiene secretos).
#
# Produccion: Genera SECRET_KEY con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# -----------------------------------------------------------------------------
# ENTORNO
# -----------------------------------------------------------------------------
# Valores: development | staging | production
ENVIRONMENT=development

# Modo debug (NUNCA true en produccion)
DEBUG=false

# -----------------------------------------------------------------------------
# BASE DE DATOS
# -----------------------------------------------------------------------------
# Formato: postgresql://usuario:contrasena@host:puerto/nombre_bd
# Ejemplo local:  postgresql://unives_user:unives_password@localhost:5433/plataforma_escolar
# Ejemplo Docker: postgresql://unives_user:unives_password@db:5432/plataforma_escolar
DATABASE_URL=postgresql://unives_user:unives_password@localhost:5433/plataforma_escolar
POSTGRES_USER=unives_user
POSTGRES_PASSWORD=unives_password
POSTGRES_DB=plataforma_escolar

# -----------------------------------------------------------------------------
# SEGURIDAD - JWT
# -----------------------------------------------------------------------------
# OBLIGATORIO en produccion. Genera una clave segura:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Minimo 32 caracteres aleatorios.
SECRET_KEY=GENERA_UNA_CLAVE_SEGURA_CON_EL_COMANDO_ANTERIOR
# Lista de llaves anteriores separadas por coma para permitir rotar tokens (opcional)
OLD_SECRET_KEYS=

# Algoritmo de firma JWT (no cambiar salvo necesidad)
JWT_ALGORITHM=HS256

# Duracion del token en minutos (1440 = 24 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Duracion del refresh token (por defecto 7 dias)
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Origenes permitidos separados por coma. En produccion restringir a dominios reales.
# Ejemplo: https://plataforma.unives.edu.mx,https://admin.unives.edu.mx
# Desarrollo: http://localhost:8080 (evitar * en produccion)
CORS_ORIGINS=http://localhost:8080

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
# Host y puerto del API (para documentacion y logs)
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# ALMACENAMIENTO
# -----------------------------------------------------------------------------
# Directorio base para uploads de documentos (ruta relativa o absoluta)
UPLOAD_DIR=uploads
# Tipos MIME permitidos para uploads
ALLOWED_UPLOAD_TYPES=application/pdf,image/jpeg,image/png,text/csv
# Limite de tamano para uploads en MB
MAX_UPLOAD_SIZE_MB=5
# Limite de tamano para CSV de importaciones en MB
MAX_CSV_SIZE_MB=5

# -----------------------------------------------------------------------------
# RATE LIMITING LOGIN
# -----------------------------------------------------------------------------
# Intentos maximos y ventana en segundos para /token
LOGIN_RATE_MAX_ATTEMPTS=5
LOGIN_RATE_WINDOW_SECONDS=900

# -----------------------------------------------------------------------------
# ALEMBIC (migraciones)
# -----------------------------------------------------------------------------
# Si esta definido, Alembic usa esta URL en lugar de alembic.ini
# Util para CI/CD y despliegues donde la URL viene de variables de entorno
# ALEMBIC_DATABASE_URL=postgresql://...
